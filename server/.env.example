# Server environment variables
# Copy to server/.env and fill in values

MONGODB_URI=mongodb://localhost:27017/automation-saas
JWT_SECRET=change-this-to-a-long-random-string
CLIENT_URL=http://localhost:5173
PORT=3001

# Stripe (test mode) — optional until you are ready to test checkout
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Optional: override placeholder Stripe Price IDs per product tier
# REAL_ESTATE_STARTER_PRICE_ID=price_xxx
# REAL_ESTATE_PRO_PRICE_ID=price_xxx
# REAL_ESTATE_AGENCY_PRICE_ID=price_xxx
# SOCIAL_MEDIA_STARTER_PRICE_ID=price_xxx
# SOCIAL_MEDIA_PRO_PRICE_ID=price_xxx
# SOCIAL_MEDIA_AGENCY_PRICE_ID=price_xxx
# AI_CHATBOT_STARTER_PRICE_ID=price_xxx
# AI_CHATBOT_PRO_PRICE_ID=price_xxx
# AI_CHATBOT_AGENCY_PRICE_ID=price_xxx
